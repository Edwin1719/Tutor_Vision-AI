# Archivo de ejemplo para la configuración de variables de entorno

# Requerido: Clave de API de Google Gemini
# Obtén la tuya en https://makersuite.google.com/
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# Opcional: Para borrar variables de entorno de proxy (establecer en "1" para activar)
# CLEAR_PROXY=1
